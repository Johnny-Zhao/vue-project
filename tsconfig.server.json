{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["server/**/*.ts", "server/**/*.d.ts"],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "noEmit": true,
    "composite": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo"
  }
}
