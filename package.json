{
  "name": "vue-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "run-p server:dev dev",
    "dev:test": "vite --mode test",
    "dev:prod": "vite --mode production",
    "build": "run-p type-check type-check:server \"build-only {@}\" --",
    "build:test": "run-p type-check type-check:server \"build-only --mode test\" --",
    "build:prod": "run-p type-check type-check:server \"build-only --mode production\" --",
    "preview": "vite preview",
    "server:dev": "node --watch --import jiti/register server/index.ts",
    "server:start": "node --import jiti/register server/index.ts",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "type-check:server": "tsc -p tsconfig.server.json",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "mcp:postgres": "node --import jiti/register mcp/local-postgres.ts",
    "mcp:postgres:test": "node --import jiti/register mcp/local-postgres.ts --test-connection",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.13.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.2",
    "element-plus": "^2.14.0",
    "express": "^5.1.0",
    "openai": "^6.4.0",
    "pg": "^8.21.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "~10.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "less": "^4.4.2",
    "lint-staged": "^16.2.6",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,mts,cts}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,less,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
